# Mentis Backend — Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur.

# Supabase Postgres connection string.
# Supabase Project Settings → Database → Connection string → URI
# Şifreyi DOĞRUDAN URL içine yazmayı unutma.
DATABASE_URL="postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# JWT için imzalama anahtarı. Production'da rastgele 64+ karakter olmalı.
JWT_SECRET="mentis-dev-secret-change-me-in-production"

# Terapist ana şifresi. Demo için sabit. (sunum: "terapist123")
THERAPIST_MASTER_PASSWORD="terapist123"

# Backend port. Render üretirken kendi PORT'unu enjekte eder.
PORT=3000

# Çalışma ortamı. development | production
NODE_ENV="development"
